<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="kit_id" class="dependency_injection_usingMap.Kit">
        <constructor-arg name="name" value="SG"> </constructor-arg>
        <constructor-arg name="items">
           <map>
               <entry key="Bet" value="50000">   </entry>
            <entry key="Ball" value="4100">   </entry>
        <entry key="Helmet" value="2000">   </entry>


           </map>
        </constructor-arg>
    </bean>

</beans>